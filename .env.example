# =====================================================
# SENTINEL - Configuração de Ambiente
# =====================================================

# === APLICAÇÃO ===
APP_NAME=Sentinel
APP_ENV=production
LOG_LEVEL=INFO
TIMEZONE=America/Sao_Paulo

# === BANCO DE DADOS ===
DATABASE_URL=sqlite:///./data/sentinel.db

# === TELEGRAM BOT ===
# Obtenha o token criando um bot com @BotFather no Telegram
# Veja: CONFIGURAR_BOT_TELEGRAM.txt
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_USER_IDS=

# Exemplo preenchido:
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_ADMIN_USER_IDS=987654321,123456789

# === CALENDÁRIOS ===
# URLs dos feeds iCal das plataformas
AIRBNB_ICAL_URL=https://www.airbnb.com/calendar/ical/XXXXXXX.ics
BOOKING_ICAL_URL=https://admin.booking.com/hotel/hoteladmin/ical/XXXXXXX.ics
CALENDAR_SYNC_INTERVAL_MINUTES=30

# === DADOS DO IMÓVEL ===
PROPERTY_NAME=Apartamento 2 Quartos - Goiânia
PROPERTY_ADDRESS=Rua Exemplo, 123, Setor Central, 74000-000 Goiânia - GO
CONDO_NAME=Condomínio Exemplo
CONDO_ADMIN_NAME=Administração do Condomínio

# === FEATURES ===
ENABLE_AUTO_DOCUMENT_GENERATION=false
ENABLE_CONFLICT_NOTIFICATIONS=true

# =====================================================
# MVP2 e MVP3 - Recursos Futuros
# =====================================================

# === GMAIL API (MVP3) ===
GMAIL_CREDENTIALS_FILE=./credentials.json
GMAIL_TOKEN_FILE=./token.json
GMAIL_CHECK_INTERVAL_MINUTES=5
ENABLE_EMAIL_MONITORING=false

# === OLLAMA/GEMMA 3 (MVP3) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_TEMPERATURE=0.1

# === DOCUMENTOS (MVP2) ===
TEMPLATE_DIR=./templates
OUTPUT_DIR=./data/generated_docs
DEFAULT_TEMPLATE=autorizacao_condominio.docx
